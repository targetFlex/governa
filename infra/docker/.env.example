# ============================================================
# infra/docker — variáveis de ambiente para docker-compose
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# ============================================================

# --- Datadog (OTel Collector → Datadog) ---
# Obtenha em: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=<sua-datadog-api-key>

# Site Datadog (padrão US1 — ajuste se sua org estiver em outro site)
# US1:  datadoghq.com  (padrão)
# EU:   datadoghq.eu
# US3:  us3.datadoghq.com
# US5:  us5.datadoghq.com
# GOV:  ddog-gov.com
DD_SITE=datadoghq.com

# --- Deployment environment (aparece nos logs/traces como atributo) ---
# development | staging | production
DEPLOYMENT_ENV=development
