# ============================================================
# AICOCKPIT — Production Environment Variables
# Copie este arquivo para .env e preencha TODOS os valores.
# NUNCA commite o .env com valores reais.
# ============================================================

# ── Domínio e TLS ────────────────────────────────────────────────────────
DOMAIN=aicockpit.com.br
ACME_EMAIL=admin@aicockpit.com.br

# ACME CA Server:
#   Staging (default — use até DNS estar propagado e testado):
#     https://acme-staging-v02.api.letsencrypt.org/directory
#   Produção (troque após validar staging):
#     https://acme-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# ── Imagens Docker (GHCR) ────────────────────────────────────────────────
# IMAGE_OWNER = username/org do GitHub que hospeda os pacotes GHCR
IMAGE_OWNER=<github-username>
IMAGE_TAG=latest

# ── Banco de dados ───────────────────────────────────────────────────────
POSTGRES_USER=governa
POSTGRES_PASSWORD=<senha-forte-min-32-chars>
POSTGRES_DB=governa_prod

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<senha-forte-min-32-chars>

# ── Segredos da aplicação ────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=<minimo-64-chars-aleatorio>

# Gere com: openssl rand -base64 32
PII_HMAC_SECRET=<minimo-32-chars-aleatorio>

# ── Integração Protheus ──────────────────────────────────────────────────
PROTHEUS_BASE_URL=https://protheus.exemplo.com.br/rest
PROTHEUS_AUTH_MODE=oauth2
PROTHEUS_CLIENT_ID=<client-id>
PROTHEUS_CLIENT_SECRET=<client-secret>
PROTHEUS_BASIC_USER=<usuario-api>
PROTHEUS_BASIC_PASS=<senha-api>

# ── Observabilidade ──────────────────────────────────────────────────────
# Datadog — https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=<datadog-api-key>
DD_SITE=datadoghq.com

# SigNoz — https://signoz.io/docs/ingestion/signoz-cloud/overview/
SIGNOZ_OTLP_ENDPOINT=https://ingest.signoz.io:4317
SIGNOZ_INGESTION_KEY=<signoz-ingestion-key>
