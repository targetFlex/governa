            "match": "type"
          },
          "$.body.data[*].endereco.municipio": {
            "match": "type"
          },
          "$.body.data[*].loja": {
            "match": "type"
          },
          "$.body.data[*].nome": {
            "match": "type"
          },
          "$.body.data[*].telefonePseudo": {
            "match": "type"
          },
          "$.body.data[*].tipo": {
            "match": "regex",
            "regex": "^(FISICA|JURIDICA)$"
          }
        },
        "status": 200
      }
    },
