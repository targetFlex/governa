{
  "consumer": { "name": "governa-ui" },
  "provider": { "name": "governa-core" },
  "interactions": [
    {
      "description": "GET /agents — tenant sem agentes retorna lista vazia",
      "providerState": "tenant-pact-001 não tem agentes",
      "request": {
        "method": "GET",
        "path":   "/agents",
        "headers": { "Authorization": "Bearer PACT_TEST_TOKEN" }
      },
      "response": {
        "status": 200,
        "body": { "data": [], "total": 0 }
      }
    },
    {
      "description": "GET /agents/:id — agente existente retorna 200",
      "providerState": "agente agent-pact-001 existe",
      "request": {
        "method": "GET",
        "path":   "/agents/agent-pact-001",
        "headers": { "Authorization": "Bearer PACT_TEST_TOKEN" }
      },
      "response": {
        "status": 200,
        "matchingRules": {
          "$.body.data.id":           { "match": "type" },
          "$.body.data.name":         { "match": "type" },
          "$.body.data.description":  { "match": "type" },
          "$.body.data.ownerId":      { "match": "type" },
          "$.body.data.modelId":      { "match": "type" },
          "$.body.data.createdAt":    { "match": "type" },
          "$.body.data.updatedAt":    { "match": "type" }
        },
        "body": {
          "data": {
            "id":          "agent-pact-001",
            "name":        "Pact Agent Alpha",
            "description": "Agente de teste Pact",
            "status":      "SANDBOX",
            "ownerId":     "00000000-0000-0000-0000-000000000001",
            "policyId":    null,
            "modelId":     "claude-haiku-4-5",
            "tools":       [],
            "createdAt":   "2026-01-01T00:00:00.000Z",
            "updatedAt":   "2026-01-01T00:00:00.000Z",
            "lastActiveAt": null
          }
        }
      }
    },
    {
      "description": "GET /agents/:id — agente inexistente retorna 404",
      "providerState": "agente agent-pact-999 não existe",
      "request": {
        "method": "GET",
        "path":   "/agents/agent-pact-999",
        "headers": { "Authorization": "Bearer PACT_TEST_TOKEN" }
      },
      "response": {
        "status": 404,
        "body": {
          "error": "Agent not found: agent-pact-999",
          "code":  "AGENT_NOT_FOUND"
        }
      }
    },
    {
      "description": "POST /agents — cria agente com dados válidos retorna 201",
      "providerState": "tenant-pact-001 pode criar agentes",
      "request": {
        "method": "POST",
        "path":   "/agents",
        "headers": {
          "Authorization": "Bearer PACT_TEST_TOKEN",
          "Content-Type":  "application/json"
        },
        "body": {
          "name":        "Novo Agente Pact",
          "description": "Criado via contrato Pact",
          "ownerId":     "00000000-0000-0000-0000-000000000001",
          "policyId":    null,
          "modelId":     "claude-haiku-4-5",
          "tools":       []
        }
      },
      "response": {
        "status": 201,
        "matchingRules": {
          "$.body.data.id":        { "match": "type" },
          "$.body.data.createdAt": { "match": "type" },
          "$.body.data.updatedAt": { "match": "type" }
        },
        "body": {
          "data": {
            "id":           "any-uuid",
            "name":         "Novo Agente Pact",
            "description":  "Criado via contrato Pact",
            "status":       "SANDBOX",
            "ownerId":      "00000000-0000-0000-0000-000000000001",
            "policyId":     null,
            "modelId":      "claude-haiku-4-5",
            "tools":        [],
            "createdAt":    "2026-01-01T00:00:00.000Z",
            "updatedAt":    "2026-01-01T00:00:00.000Z",
            "lastActiveAt": null
          }
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": { "version": "2.0.0" }
  }
}
