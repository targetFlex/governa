# ============================================================
# governa-core — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# ============================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000

# --- Banco de dados (Postgres via Prisma) ---
# Local (docker-compose): postgresql://governa:governa_dev_pw@localhost:5432/governa_dev
DATABASE_URL=postgresql://governa:<password>@<host>:5432/governa_dev?schema=public

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://localhost:6379

# --- Gateway TOTVS ---
# URL do governa-gateway. Em docker-compose: http://governa-gateway:3100
# Em dev local sem Docker: http://localhost:3100
GATEWAY_BASE_URL=http://localhost:3100

# --- Autenticação JWT ---
# Mínimo 32 caracteres — rotacionar invalida todos os tokens existentes
JWT_SECRET=<mínimo-32-chars-aleatórios>

# --- PII (ofuscação de dados sensíveis) ---
# Mínimo 32 caracteres — rotacionar invalida tokens de PII existentes
PII_HMAC_KEY=<mínimo-32-chars-aleatórios>

# --- Tenant padrão (dev) ---
DEFAULT_TENANT_ID=target-flex-dev

# --- Anthropic (agentes AI) ---
ANTHROPIC_API_KEY=sk-ant-<sua-chave>

# --- OpenTelemetry (observabilidade) ---
# Endpoint do OTel Collector (OTLP HTTP).
# Docker Compose local: http://localhost:4318
# SigNoz cloud: https://<ingest-host>:443
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Nome do serviço no SigNoz/Jaeger (aparece nos traces e métricas)
OTEL_SERVICE_NAME=governa-core

# Sampler: parentbased_always_on (100%) | parentbased_traceidratio (probabilístico)
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1.0

# Desabilitar OTel completamente em testes ou ambientes sem coletor
# OTEL_SDK_DISABLED=true
