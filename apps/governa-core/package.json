{
  "name": "governa-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:edge": "jest --config jest.config.js --testPathPattern=test/edge --passWithNoTests",
    "test:unit": "jest --config jest.config.js --testPathIgnorePatterns=test/edge --passWithNoTests",
    "test:coverage": "jest --config jest.config.js --coverage --passWithNoTests",
    "test:integration": "jest --config jest.integration.config.js --passWithNoTests",
    "test:integration:coverage": "jest --config jest.integration.config.js --coverage --passWithNoTests",
    "test:all": "pnpm test:coverage && pnpm test:integration",
    "pact:test": "jest --config jest.pact.config.js --runInBand --passWithNoTests",
    "pact:verify": "jest --config jest.pact.config.js --testPathPattern=provider --runInBand --passWithNoTests",
    "pact:publish": "node -e \"const { Publisher } = require('@pact-foundation/pact'); new Publisher({ pactFilesOrDirs: ['test/pact/pacts'], pactBroker: 'http://localhost:9292', pactBrokerUsername: 'pact', pactBrokerPassword: 'pact_dev_pw', consumerVersion: require('./package.json').version, tags: ['main'] }).publishPacts().then(() => console.log('Pacts publicados')).catch(e => { console.error(e); process.exit(1); })\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.53.0",
    "@opentelemetry/auto-instrumentations-node": "^0.53.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.53.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/sdk-logs": "^0.53.0",
    "@opentelemetry/sdk-metrics": "^1.26.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@prisma/client": "^5.14.0",
    "@types/express": "^4.17.21",
    "bullmq": "^5.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "prisma": "^5.14.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^12.5.2",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "axios": "^1.7.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
