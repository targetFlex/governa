# ============================================================
# governa-gateway — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# ============================================================

# --- Protheus REST API ---
PROTHEUS_BASE_URL=https://protheus.targetflex.com.br/rest
PROTHEUS_CLIENT_ID=governa_client
PROTHEUS_CLIENT_SECRET=<secret>
PROTHEUS_BASIC_USER=governa_api
PROTHEUS_BASIC_PASS=<password>

# Modo de autenticação: oauth2 | basic
PROTHEUS_AUTH_MODE=oauth2

# Renovar token N segundos antes do vencimento (evitar uso de token expirado)
PROTHEUS_TOKEN_TTL_BUFFER_S=30

# --- HTTP ---
PROTHEUS_TIMEOUT_MS=10000
PROTHEUS_MAX_RETRIES=3

# --- PII (sessão 2.3) ---
# Mínimo 32 caracteres — rotacionar invalida todos os tokens existentes
PII_HMAC_SECRET=<mínimo-32-chars>

# --- Servidor ---
# Porta em que o gateway escuta. Padrão: 3100
GATEWAY_PORT=3100
NODE_ENV=development
